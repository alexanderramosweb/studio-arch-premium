---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../sections/contact/ContactForm.astro";
import "../styles/components/contact.css";
---

<BaseLayout title="Contacto">
  <section class="contact-hero">
    <div class="container">
      <div class="contact-hero__content hero__content--animated">
        <p class="contact-hero__eyebrow">Contacto Privado</p>

        <h1 class="contact-hero__title split-reveal">
          Iniciemos una conversación sobre arquitectura contemporánea.
        </h1>

        <p class="contact-hero__description">
          Agenda una presentación privada y conoce nuestra visión, proyectos y
          experiencias residenciales cuidadosamente concebidas.
        </p>
      </div>
    </div>
  </section>
  <ContactForm />
</BaseLayout>
