---
import "../styles/components/herosection.css";
import heroDesktop from "/src/assets/images/hero/hero-desktop.webp";

import heroMobile from "/src/assets/images/hero/hero-mobile.webp";
---

<section class="hero">
  <div class="hero__background">
    <picture>
      <source srcset={heroMobile.src} media="(max-width: 768px)" />

      <img
        src={heroDesktop.src}
        alt="Arquitectura moderna premium"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
  </div>

  <div class="hero__overlay"></div>

  <div class="container">
    <div class="hero__content hero__content--animated">
      <p class="hero__eyebrow">Arquitectura • Exclusividad • Lifestyle</p>

      <h1 class="hero__title split-reveal">
        Espacios diseñados para una nueva forma de vivir.
      </h1>

      <p class="hero__description">
        Creamos experiencias residenciales premium donde la arquitectura
        contemporánea, el diseño y la elegancia convergen en perfecta armonía.
      </p>

      <a href="/projects" class="hero__button"> Descubrir proyectos </a>
    </div>
  </div>
</section>
