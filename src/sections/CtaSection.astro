---
import "../styles/components/ctasection.css";
---

<section class="cta section">
  <div class="container">
    <div class="cta__content" data-reveal-group>
      <p class="cta__eyebrow">Agenda una presentación privada</p>

      <h2 class="cta__title">
        Descubre una nueva forma de habitar la arquitectura contemporánea.
      </h2>

      <p class="cta__description">
        Conoce el proyecto, explora la visión arquitectónica y recibe atención
        personalizada para encontrar la residencia ideal.
      </p>

      <a href="#" class="cta__button"> Solicitar información </a>
    </div>
  </div>
</section>
