---
import "../styles/components/amenitiessection.css";
---

<section class="amenities section">
  <div class="container">
    <div class="amenities__intro" data-reveal-group>
      <p class="amenities__eyebrow">Lifestyle & Experiencia</p>

      <h2 class="amenities__title">
        Espacios concebidos para una vida extraordinaria.
      </h2>
    </div>

    <div class="amenities__list">
      <div class="amenities__item" data-reveal>
        <span class="amenities__number">01</span>

        <div>
          <h3>Wellness & Spa</h3>

          <p>Áreas diseñadas para equilibrio, relajación y bienestar diario.</p>
        </div>
      </div>

      <div class="amenities__item" data-reveal>
        <span class="amenities__number">02</span>

        <div>
          <h3>Rooftop Privado</h3>

          <p>Vistas panorámicas y espacios sociales cuidadosamente curados.</p>
        </div>
      </div>

      <div class="amenities__item" data-reveal>
        <span class="amenities__number">03</span>

        <div>
          <h3>Concierge 24/7</h3>

          <p>
            Atención personalizada para una experiencia residencial impecable.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
