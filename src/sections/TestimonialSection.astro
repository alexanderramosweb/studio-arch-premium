---
import { Image } from "astro:assets";

import testimonialImage from "../assets/images/gallery/gallery1.webp";

import "../styles/components/testimonialsection.css";
---

<section class="testimonial section">
  <div class="container" data-reveal>
    <div class="testimonial__grid">
      <div class="testimonial__content">
        <p class="testimonial__quote">
          “Una experiencia residencial donde la arquitectura deja de ser
          únicamente estética y se convierte en una forma de vivir.”
        </p>

        <div class="testimonial__author">
          <span>Architectural Living Magazine</span>
          <span>Edición 2026</span>
        </div>
      </div>

      <div class="testimonial__media">
        <Image
          src={testimonialImage}
          alt="Residencia arquitectónica premium"
          widths={[600, 900, 1200]}
          sizes="(max-width: 768px) 100vw, 50vw"
          format="webp"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
