---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Studio Arch",

  description = "Arquitectura contemporánea concebida como una experiencia residencial de lujo, donde diseño, luz y materialidad convergen en espacios atemporales.",

  image = "/og-cover.webp",
} = Astro.props;

/* ================================
   URL CANÓNICA
================================ */

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <!-- ================================
         CONFIGURACIÓN BASE
    ================================= -->

    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <!-- ================================
         SEO BÁSICO
    ================================= -->

    <meta name="description" content={description} />

    <meta
      name="keywords"
      content="arquitectura, arquitectura de lujo, estudio de arquitectura, diseño contemporáneo, residencias premium"
    />

    <meta name="author" content="Studio Arch" />

    <!-- ================================
         URL CANÓNICA
    ================================= -->

    <link rel="canonical" href={canonicalURL} />

    <!-- ================================
         COLOR DEL NAVEGADOR
    ================================= -->

    <meta name="theme-color" content="#111111" />

    <!-- ================================
         FAVICON
    ================================= -->

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- ================================
         OPEN GRAPH
    ================================= -->

    <meta property="og:title" content={title} />

    <meta property="og:description" content={description} />

    <meta property="og:type" content="website" />

    <meta property="og:image" content={image} />

    <meta property="og:url" content={canonicalURL} />

    <!-- ================================
         TWITTER / X
    ================================= -->

    <meta name="twitter:card" content="summary_large_image" />

    <meta name="twitter:title" content={title} />

    <meta name="twitter:description" content={description} />

    <meta name="twitter:image" content={image} />
  </head>

  <body>
    <main>
      <Header />

      <slot />

      <Footer />

      <!-- ================================
           MAIN SCRIPT
      ================================= -->

      <script>
        import("../scripts/main.ts");
      </script>
    </main>
  </body>
</html>
